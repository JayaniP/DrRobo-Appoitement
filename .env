# ─────────────────────────────────────────────────────────────
# DrRobo Telehealth — environment configuration
# ─────────────────────────────────────────────────────────────

# Port this combined app listens on (frontend + API gateway).
PORT=4000

# aiRender / IAMyHealth Schedule Meeting backend.
TELEHEALTH_API_BASE_URL=https://airender.co:8000
TELEHEALTH_SCHEDULE_PATH=/receive-data

# Base URL for fallback meeting links when the aiRender backend is unreachable.
PUBLIC_MEETING_BASE_URL=https://airender.co

# Organization / plan IDs sent on every Schedule Meeting call.
# Replace these with the real values aiRender assigned to your organization
# (the placeholder values below are from the integration doc and will NOT
# return real meeting URLs from aiRender — they'll get an empty response).
TELEHEALTH_ORG_NAME=IAMyHealth
TELEHEALTH_ORG_ID=ORG1234567890
TELEHEALTH_PLAN_ID=PLANENTP1234567890

# Set to "true" to force-skip the live aiRender call and always use the
# built-in aiRender simulator. Useful during demos before your credentials
# are registered with aiRender.
TELEHEALTH_FORCE_MOCK=false

# Flip to "true" once aiRender has confirmed your organization & doctor
# accounts are registered AND their /?data=... URL actually opens a real
# room without Firebase/SSL errors. Until then, "Join" buttons route
# through the local /demo-room.html so the prototype always works.
USE_AIRENDER_FOR_JOIN=false

# ── Email (booking invites) ──────────────────────────────────────────────
# Default recipients used when the booking form omits them.
DEMO_DOCTOR_EMAIL=ceo@iamyhealth.com
DEMO_PATIENT_EMAIL=jayanipatel23@gmail.com

# Gmail SMTP. To send real emails:
#   1. Turn on 2FA for your Gmail account.
#   2. Generate an "App Password" at https://myaccount.google.com/apppasswords
#   3. Paste the Gmail address into SMTP_USER and the 16-char App Password into SMTP_PASS.
# If SMTP_USER / SMTP_PASS are left empty, the server logs the full email to
# the console instead of sending — perfect for demos.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=jayanipatel23@gmail.com
SMTP_PASS=ctuv aogg ohjd ndbg
MAIL_FROM_NAME=DrRobo Telehealth
MAIL_FROM=jayanipatel23@gmail.com

# Public URL of *this* DrRobo app — used to rewrite relative /demo-room.html
# links in outgoing emails into absolute URLs. For local demos leave as-is;
# when deployed change to your real domain (e.g. https://drrobo.example.com).
PUBLIC_APP_BASE_URL=http://localhost:4000
